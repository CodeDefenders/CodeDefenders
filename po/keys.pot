msgstr "No renaming of methods or fields, and no additional methods or fields"

#: src/main/webapp/jsp/help.jsp:120
msgid "Moderate"
msgstr "Moderate"

#: src/main/webapp/jsp/help.jsp:122
msgid "No changes to comments"
msgstr "No changes to comments"

#: src/main/webapp/jsp/help.jsp:123
msgid "No additional logical operators (&&, ||)"
msgstr "No additional logical operators (&&, ||)"

#: src/main/webapp/jsp/help.jsp:124
msgid "No ternary operators"
