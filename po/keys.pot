msgstr "No new control structures (switch, if, for, ...)"

#: src/main/webapp/jsp/help.jsp:128
msgid "Strict"
msgstr "Strict"

#: src/main/webapp/jsp/help.jsp:130
msgid "No reflection"
msgstr "No reflection"

